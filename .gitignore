# ============================================================
#  MATH-86 Quanto Project — .gitignore
# ============================================================

# --- Data — track everything (raw CSVs, processed CSVs, figures) ------------
# No exclusions under data/ or outputs/ — commit all of it.

# --- Python artefacts ----------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg
.eggs/

# --- Virtual environments ------------------------------------
.venv/
venv/
env/
.env

# --- IDEs / editors ------------------------------------------
.vscode/
.idea/
*.swp
*~

# --- macOS ---------------------------------------------------
.DS_Store
.AppleDouble

# --- Windows -------------------------------------------------
Thumbs.db
desktop.ini

# --- Jupyter -------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# --- Test / coverage artefacts -------------------------------
.pytest_cache/
.coverage
htmlcov/
