# Data files — never commit raw or processed data
data/raw/
data/processed/

# Keep empty placeholder files so the directory tree is preserved in git
!data/raw/.gitkeep
!data/processed/.gitkeep

# Python bytecode
__pycache__/
*.py[cod]
*.pyo

# VS Code workspace settings
.vscode/

# Python virtual environments (if created)
venv/
.venv/
env/

# Jupyter / IPython
.ipynb_checkpoints/
*.ipynb

# OS artifacts
Thumbs.db
.DS_Store
desktop.ini

# Build / distribution artifacts
*.egg-info/
dist/
build/
